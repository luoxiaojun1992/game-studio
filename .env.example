# Game Dev Studio Docker 环境变量配置

# ==================== 端口配置 ====================
# Studio 后端服务端口（默认 3000）
STUDIO_BACKEND_PORT=3000

# Studio 前端服务端口（默认 5173）
STUDIO_FRONTEND_PORT=5173

# Star Office UI 服务端口（默认 19000）
STAR_OFFICE_PORT=19000

# ==================== CodeBuddy API 配置 ====================
# CodeBuddy API Key（用于 Agent SDK 认证）
# 默认值为空字符串，可在运行时通过外部注入
CODEBUDDY_API_KEY=

# ==================== Star Office 集成配置 ====================
# Star Office 接入密钥（用于 Agent 注册）
# 默认值: ocj_example_team_01
STAR_OFFICE_JOIN_KEY=ocj_example_team_01

# Star Office 最大并发 Agent 数量（每个密钥）
# 默认值: 100
STAR_OFFICE_MAX_CONCURRENT=100

# Star Office 后端服务密钥（建议至少 24 字符）
STAR_OFFICE_SECRET=your-secret-key-here-min-24-chars

# Star Office 资源面板密码
ASSET_DRAWER_PASS=secure-pass-1234

# ==================== 前端构建变量 ====================
# 前端 API 地址（Docker 默认连接后端容器）
VITE_API_BASE=http://studio-backend:3000

# 前端嵌入 Star Office 地址（Docker 默认连接 Star Office 容器）
VITE_STAR_OFFICE_UI_URL=http://star-office-ui:19000

# ==================== 后端服务集成变量 ====================
# Star Office UI 基础地址（后端由该地址推导同步端点，不再使用独立覆盖变量）
STAR_OFFICE_UI_URL=http://127.0.0.1:19000

# Creator 服务端口（容器对外）
CREATOR_PORT=8080

# 后端访问 Creator 服务地址
CREATOR_SERVICE_URL=http://creator:8080

# ==================== 可选：高级配置 ====================
# 同步防抖时间（毫秒，默认 300）
# STAR_OFFICE_SYNC_DEBOUNCE_MS=300

# 健康检查间隔（毫秒，默认 10000）
# STAR_OFFICE_HEALTH_CHECK_INTERVAL_MS=10000

# ==================== SonarQube 配置 ====================
# SonarQube 服务端口（默认 9000）
SONARQUBE_PORT=9000

# SonarQbe PostgreSQL 密码
SONARQUBE_DB_PASSWORD=sonarpass
