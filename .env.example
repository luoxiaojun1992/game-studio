# Game Dev Studio Docker 环境变量配置

# ==================== 端口配置 ====================
# Studio 后端服务端口（默认 3000）
STUDIO_BACKEND_PORT=3000

# Studio 前端服务端口（默认 5173）
STUDIO_FRONTEND_PORT=5173

# Star Office UI 服务端口（默认 19000）
STAR_OFFICE_PORT=19000

# ==================== CodeBuddy API 配置 ====================
# CodeBuddy API Key（用于 Agent SDK 认证）
# 默认值为空字符串，可在运行时通过外部注入
CODEBUDDY_API_KEY=

# ==================== Star Office 集成配置 ====================
# Star Office 接入密钥（用于 Agent 注册）
# 默认值: ocj_example_team_01
STAR_OFFICE_JOIN_KEY=ocj_example_team_01

# Star Office 最大并发 Agent 数量（每个密钥）
# 默认值: 5
STAR_OFFICE_MAX_CONCURRENT=5

# ==================== 可选：高级配置 ====================
# 同步防抖时间（毫秒，默认 300）
# STAR_OFFICE_SYNC_DEBOUNCE_MS=300

# 健康检查间隔（毫秒，默认 10000）
# STAR_OFFICE_HEALTH_CHECK_INTERVAL_MS=10000
