{
  "name": "game-dev-studio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "start": "node dist-server/server/index.js",
    "mock:server": "node tests/mock-server/codebuddy-sdk-mock-server.mjs",
    "test:ui": "playwright test -c tests/ui/playwright.config.ts",
    "test:ui:coverage": "node tests/ui/scripts/check-ui-coverage.mjs tests/ui/artifacts/playwright-report/results.json tests/ui/coverage/cases.json",
    "test:ui:allure": "bash tests/ui/scripts/generate-ui-allure.sh",
    "test:ui:ci": "bash tests/ui/scripts/test-ui-ci.sh"
  },
  "dependencies": {
    "@tdesign-react/aigc": "^0.1.0-alpha.1",
    "@tdesign-react/chat": "^1.0.2",
    "@tencent-ai/agent-sdk": "^0.3.43",
    "better-sqlite3": "^12.6.2",
    "express": "^4.18.2",
    "lucide-react": "^0.563.0",
    "minio": "^7.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.0",
    "tdesign-icons-react": "^0.5.0",
    "tdesign-react": "^1.12.0",
    "unzipper": "^0.12.3",
    "uuid": "^9.0.0",
    "yazl": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^9.0.7",
    "@types/yazl": "^3.3.1",
    "@vitejs/plugin-react": "^4.2.1",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "less": "^4.3.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vite": "^5.0.10"
  }
}
